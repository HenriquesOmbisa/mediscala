{
  "name": "mediscala",
  "version": "0.0.1",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:services": "docker compose -f docker-compose.dev.yml up -d",
    "dev:services:down": "docker compose -f docker-compose.dev.yml down",
    "dev:full": "bun run dev:services && sleep 2 && turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "turbo": "^2.9.6",
    "typescript": "^5.7.3"
  }
}
