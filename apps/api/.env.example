DATABASE_URL=postgresql://mediscala:mediscala@localhost:5432/mediscala
# Produção/local simples: 6379. Se usar docker-compose.dev.yml: Redis exposto em 6380 → redis://localhost:6380
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
CORS_ORIGINS=http://localhost:5173,exp://localhost:8081
UPLOAD_DIR=uploads
# Sugestões de escala: dia/período relativos a este fuso (evita servidor UTC a marcar “dia errado”).
APP_TIMEZONE=Africa/Luanda

